#!/usr/bin/env bash
set -euo pipefail

export HOME="${HOME:-$(eval echo ~$(whoami))}"
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:$HOME/.asdf/shims:${PATH:-/usr/bin:/bin:/usr/sbin:/sbin}"

if [ -f "$HOME/.asdf/asdf.sh" ]; then
  . "$HOME/.asdf/asdf.sh"
elif command -v brew >/dev/null 2>&1 && [ -f "$(brew --prefix asdf)/libexec/asdf.sh" ]; then
  . "$(brew --prefix asdf)/libexec/asdf.sh"
fi

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
APP_ROOT="${SHEAF_APP_ROOT:-$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)}"

cd "$APP_ROOT"

# shellcheck disable=SC1091
. "$SCRIPT_DIR/lib/runtime_env.sh"
load_sheaf_env "$APP_ROOT"

NODE="${SHEAF_NODE:-$(sheaf_node_name)}"
set_sheaf_elixir_node_args "$NODE"
COOKIE_ARGS=()
while IFS= read -r arg; do
  COOKIE_ARGS+=("$arg")
done < <(sheaf_cookie_args)

exec elixir "$SHEAF_ELIXIR_NODE_FLAG" "$SHEAF_ELIXIR_NODE_VALUE" "${COOKIE_ARGS[@]}" -S mix phx.server
