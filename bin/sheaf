#!/usr/bin/env bash
# Tiny CLI over the Sheaf JSON API. Pretty output by default, raw JSON with --json.
#
# Usage:
#   sheaf docs                       list all documents
#   sheaf doc ID                     show document metadata + outline
#   sheaf outline ID                 just the outline (sections only)
#   sheaf block DOC BLOCK            show one block (drill-down)
#   sheaf read DOC                   full text of a document as chunks
#   sheaf text DOC [BLOCK]           flattened plain text, optionally from one section
#   sheaf sparql 'QUERY'             run a SPARQL query, print rows as TSV
#   sheaf sparql-json 'QUERY'        run a SPARQL query, print raw JSON
#   sheaf open ID                    print the reader URL for a document/block
#
# Env:
#   SHEAF_HOST   default host, defaults to https://sheaf.less.rest
#
# Global flags:
#   --json       raw JSON instead of pretty output
#   --host URL   override host for this call

set -euo pipefail

HOST="${SHEAF_HOST:-https://sheaf.less.rest}"
RAW=0

args=()
while (($#)); do
  case "$1" in
    --json) RAW=1; shift ;;
    --host) HOST="$2"; shift 2 ;;
    -h|--help) sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) args+=("$1"); shift ;;
  esac
done
set -- "${args[@]-}"

die() { echo "sheaf: $*" >&2; exit 1; }

get() {
  curl -sSf -G "$HOST$1" "${@:2}"
}

cmd="${1:-}"
shift || true

case "$cmd" in
  docs)
    json="$(get /api/documents)"
    if (( RAW )); then echo "$json"; exit; fi
    echo "$json" | jq -r '
      .documents
      | group_by(.kind)
      | .[]
      | "\n\u001b[1m\(.[0].kind | ascii_upcase)\u001b[0m",
        (.[] |
          "  \u001b[36m\(.id)\u001b[0m  \(.title)"
          + (if .metadata.authors // [] | length > 0
              then "\n          \u001b[2m\(.metadata.authors | join(", "))"
                   + (if .metadata.year then " (\(.metadata.year))" else "" end)
                   + (if .metadata.page_count then ", \(.metadata.page_count) pp." else "" end)
                   + "\u001b[0m"
              else "" end))
    '
    ;;

  doc)
    id="${1:?usage: sheaf doc ID}"
    json="$(get "/api/documents/$id")"
    if (( RAW )); then echo "$json"; exit; fi
    echo "$json" | jq -r '
      "\u001b[1m\(.title)\u001b[0m",
      "\u001b[2m\(.iri) • \(.kind)\u001b[0m",
      "",
      "Outline:"
    '
    echo "$json" | jq -r '
      def walk(depth):
        .[] |
        "  " * depth
        + "\u001b[2m\(.number)\u001b[0m \(.title)  \u001b[2m\(.id)\u001b[0m",
        (.children | walk(depth + 1));
      .outline | walk(1)
    '
    ;;

  outline)
    id="${1:?usage: sheaf outline ID}"
    json="$(get "/api/documents/$id")"
    if (( RAW )); then echo "$json" | jq '.outline'; exit; fi
    echo "$json" | jq -r '
      def walk(depth):
        .[] |
        "  " * depth
        + "\u001b[2m\(.number)\u001b[0m \(.title)  \u001b[2m\(.id)\u001b[0m",
        (.children | walk(depth + 1));
      .outline | walk(0)
    '
    ;;

  block)
    doc="${1:?usage: sheaf block DOC BLOCK}"
    block="${2:?usage: sheaf block DOC BLOCK}"
    json="$(get "/api/documents/$doc/blocks/$block")"
    if (( RAW )); then echo "$json"; exit; fi
    echo "$json" | jq -r '
      "\u001b[1m\(.type | ascii_upcase)\u001b[0m  \u001b[2m\(.iri)\u001b[0m",
      (if .title then "\n\u001b[1m\(.title)\u001b[0m" else empty end),
      (if .text and (.text | length > 0) then "\n\(.text)" else empty end),
      (if .children | length > 0 then
         "\n\u001b[2m\(.children | length) children:\u001b[0m",
         (.children[] | "  \u001b[36m\(.id)\u001b[0m  \u001b[2m\(.type)\u001b[0m  \(.title // "")")
       else empty end)
    '
    ;;

  read)
    id="${1:?usage: sheaf read ID}"
    json="$(get "/api/documents/$id/chunks")"
    if (( RAW )); then echo "$json"; exit; fi
    echo "$json" | jq -r '
      .chunks[] |
      if .type == "section"
        then "\n\u001b[1m## \(.text)\u001b[0m"
        else "\n\(.text)  \u001b[2m[\(.id)]\u001b[0m"
      end
    '
    ;;

  text)
    id="${1:?usage: sheaf text DOC [BLOCK]}"
    block="${2:-}"
    if [[ -z "$block" ]]; then
      get "/api/documents/$id/chunks" | jq -r '.chunks | map(.text) | join("\n\n")'
    else
      get "/api/documents/$id/blocks/$block" | jq -r '
        if .text then .text else
          .children | map("\(.title // .id)") | join("\n") end'
    fi
    ;;

  sparql)
    q="${1:?usage: sheaf sparql QUERY}"
    json="$(get /api/sparql --data-urlencode "query=$q")"
    if (( RAW )); then echo "$json"; exit; fi
    if echo "$json" | jq -e 'has("boolean")' >/dev/null; then
      echo "$json" | jq -r '.boolean'
    else
      echo "$json" | jq -r '
        .head.vars as $vars
        | ([$vars | .[] | "\u001b[1m\(.)\u001b[0m"] | join("\t")),
          (.results.bindings[] |
            [$vars[] as $v | (.[$v].value // "")] | join("\t"))
      '
    fi
    ;;

  sparql-json)
    q="${1:?usage: sheaf sparql-json QUERY}"
    get /api/sparql --data-urlencode "query=$q" | jq .
    ;;

  open)
    id="${1:?usage: sheaf open ID}"
    echo "$HOST/$id"
    ;;

  ""|help|--help|-h)
    sed -n '2,24p' "$0" | sed 's/^# \{0,1\}//'
    ;;

  *)
    die "unknown command: $cmd (try 'sheaf help')"
    ;;
esac
