#!/usr/bin/env bash
# Deploy the current checkout to the running service.
# Usage: bin/deploy
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
APP_ROOT="${SHEAF_APP_ROOT:-$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)}"

cd "$APP_ROOT"

# shellcheck disable=SC1091
. "$SCRIPT_DIR/lib/runtime_env.sh"
load_sheaf_env "$APP_ROOT"

if [ "${SHEAF_SERVICE_MODE:-tmux}" = "systemd" ] && command -v systemctl >/dev/null 2>&1; then
  UNIT="${SHEAF_SYSTEMD_UNIT:-sheaf.service}"
  EXEC_START="$(systemctl --user show -p ExecStart --value "$UNIT" 2>/dev/null || true)"

  if [[ "$EXEC_START" == *"/bin/serve-prod"* ]]; then
    echo "Production service detected; building and restarting..."
    "$SCRIPT_DIR/build-prod"
    "$SCRIPT_DIR/restart"
    exit 0
  fi
fi

echo "Development service detected; building assets and hot-reloading modules..."
echo "Building assets and compiling..."
mix assets.build

echo "Checking live node for reloadable code changes..."
cat <<'EOF' | bin/rpc
app = :sheaf
ebin_dir = :code.lib_dir(app) |> List.to_string() |> Path.join("ebin")

loaded_modules =
  :code.all_loaded()
  |> Enum.map(&elem(&1, 0))
  |> MapSet.new()

new_modules =
  ebin_dir
  |> Path.join("*.beam")
  |> Path.wildcard()
  |> Enum.map(fn beam ->
    beam
    |> Path.basename(".beam")
    |> String.to_atom()
  end)
  |> Enum.reject(&MapSet.member?(loaded_modules, &1))
  |> Enum.sort()

reload_candidates =
  :code.modified_modules()
  |> Enum.uniq()
  |> Enum.sort()

reload_results =
  Enum.map(reload_candidates, fn mod ->
    :code.purge(mod)

    case :code.load_file(mod) do
      {:module, ^mod} ->
        IO.puts("  reloaded #{mod}")
        {:ok, mod}

      {:error, reason} ->
        IO.puts("  failed reload #{mod}: #{inspect(reason)}")
        {:error, mod, reason}
    end
  end)

load_results =
  Enum.map(new_modules, fn mod ->
    case :code.load_file(mod) do
      {:module, ^mod} ->
        IO.puts("  loaded new #{mod}")
        {:ok, mod}

      {:error, reason} ->
        IO.puts("  failed load new #{mod}: #{inspect(reason)}")
        {:error, mod, reason}
    end
  end)

reload_failures = Enum.filter(reload_results, &match?({:error, _, _}, &1))
load_failures = Enum.filter(load_results, &match?({:error, _, _}, &1))

case {reload_results, load_results} do
  {[], []} ->
    IO.puts("No BEAM code changes to reload. Asset build completed.")

  _ ->
    IO.puts(
      "Done. #{length(reload_results) - length(reload_failures)}/#{length(reload_results)} modified module(s) reloaded, " <>
        "#{length(load_results) - length(load_failures)}/#{length(load_results)} new module(s) loaded."
    )
end

if reload_failures != [] or load_failures != [] do
  raise "hot reload failed"
else
  :ok
end
EOF
