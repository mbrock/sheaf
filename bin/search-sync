#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

. "$SCRIPT_DIR/lib/runtime_env.sh"
require_sheaf_env "$APP_ROOT"

cd "$APP_ROOT"

ARGS_B64="$(
  for arg in "$@"; do
    printf '%s\0' "$arg"
  done | base64 | tr -d '\n'
)"

"$SCRIPT_DIR/rpc" <<EOF
args =
  "$ARGS_B64"
  |> Base.decode64!()
  |> String.split(<<0>>, trim: true)

Sheaf.Admin.sync_search_indexes(args)
""
EOF
