[Unit]
Description=Sheaf production server
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/mbrock/sheaf
Environment=MIX_ENV=prod
Environment=PHX_SERVER=true
ExecStart=/home/mbrock/sheaf/bin/env /home/mbrock/sheaf/bin/serve-prod
Restart=always
RestartSec=3
SyslogIdentifier=sheaf
TimeoutStopSec=15
KillMode=mixed
KillSignal=SIGTERM

[Install]
WantedBy=default.target
