bpe:includesAction skos:prefLabel "includes action"@en .
bpe:includesAgent skos:prefLabel "includes agent"@en .
bpe:includesObject skos:prefLabel "includes object"@en .
bpe:includesRegion skos:prefLabel "includes region"@en .
bpe:isActionIncludedIn skos:prefLabel "is action included in"@en .
bpe:isAgentIncludedIn skos:prefLabel "is agent included in"@en .
bpe:isObjectIncludedIn skos:prefLabel "is object included in"@en .
bpe:isParticipantInAction skos:prefLabel "is participant in action"@en .
bpe:isRegionIncludedIn skos:prefLabel "is region included in"@en .
