    <owl:Ontology rdf:about="http://www.ontologydesignpatterns.org/cp/owl/timeindexedsituation.owl">
        <owl:versionInfo rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0
- Revised, and added annotations for ODP publishing
0.1
- Created by Aldo Gangemi</owl:versionInfo>
        <owl:versionInfo rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.1 added rdfs:isDefinedBy for all named entities</owl:versionInfo>
        <rdfs:comment rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral">A generic pattern usable for all situations that require a temporal indexing.</rdfs:comment>
        <cpannotationschema:hasAuthor rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral">Aldo Gangemi</cpannotationschema:hasAuthor>
        <cpannotationschema:coversRequirements rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral">At what time did a certain situation occur?,What situations occurred at a certain time?</cpannotationschema:coversRequirements>
        <cpannotationschema:scenarios rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral">Mustafa&#39;s address in 2005 was in Brussels</cpannotationschema:scenarios>
        <cpannotationschema:hasUnitTest rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral">SELECT ?x ?e ?t
WHERE {
?x :forEntity ?e .
?x :atTime ?t }</cpannotationschema:hasUnitTest>
        <cpannotationschema:isSpecializationOf rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral">Situation</cpannotationschema:isSpecializationOf>
        <cpannotationschema:relatedCPs rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral">Time indexed participation,TimeIndexedClassification</cpannotationschema:relatedCPs>
        <cpannotationschema:hasComponent rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral">TimeInterval</cpannotationschema:hasComponent>
        <cpannotationschema:hasIntent rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral">To represent time indexed situations.</cpannotationschema:hasIntent>
        <cpannotationschema:hasConsequences rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral">We can represent situations that have an explicit time parameter.
In principle, this can be done already with the Situation pattern, but this provides a handy composition with the TimeInterval pattern.</cpannotationschema:hasConsequences>
        <owl:imports rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/situation.owl"/>
        <owl:imports rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/timeinterval.owl"/>
        <owl:imports rdf:resource="http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl"/>
    </owl:Ontology>
    


